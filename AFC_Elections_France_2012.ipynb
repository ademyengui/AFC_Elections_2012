   "source": [
    "# Fonction pour identifier les régions et candidats caractérisant un axe\n",
    "def analyser_axe(num_axe, n_top=5):\n",
    "    \"\"\"\n",
    "    Analyse les régions et candidats qui caractérisent un axe\n",
    "    \"\"\"\n",
    "    print(f\"\\n{'='*100}\")\n",
    "    print(f\"AXE {num_axe} - Analyse détaillée\")\n",
    "    print(f\"{'='*100}\")\n",
    "    print(f\"Inertie: {pct_inertie[num_axe-1]:.2f}% (valeur propre: {eigenvalues[num_axe-1]:.6f})\\n\")\n",
    "    \n",
    "    # Régions positives\n",
    "    idx_axe = num_axe - 1\n",
    "    regions_pos = np.argsort(coordonnees_lignes[:, idx_axe])[-n_top:]\n",
    "    regions_neg = np.argsort(coordonnees_lignes[:, idx_axe])[:n_top]\n",
    "    \n",
    "    print(f\"RÉGIONS POSITIVES (Axe {num_axe}+):\")\n",
    "    print(\"-\" * 100)\n",
    "    for i in reversed(regions_pos):\n",
    "        ctr = contributions_lignes[i, idx_axe] * 100\n",
    "        qual = qualite_lignes[i, idx_axe]\n",
    "        coord = coordonnees_lignes[i, idx_axe]\n",
    "        print(f\"{df.index[i]:20s}: Coord={coord:8.4f}  | Contribution={ctr:6.2f}% | Qualité={qual:.3f}\")\n",
    "    \n",
    "    print(f\"\\nRÉGIONS NÉGATIVES (Axe {num_axe}-):\")\n",
    "    print(\"-\" * 100)\n",
    "    for i in reversed(regions_neg):\n",
    "        ctr = contributions_lignes[i, idx_axe] * 100\n",
    "        qual = qualite_lignes[i, idx_axe]\n",
    "        coord = coordonnees_lignes[i, idx_axe]\n",
    "        print(f\"{df.index[i]:20s}: Coord={coord:8.4f}  | Contribution={ctr:6.2f}% | Qualité={qual:.3f}\")\n",
    "    \n",
    "    # Candidats\n",
    "    candidats_pos = np.argsort(coordonnees_colonnes[:, idx_axe])[-n_top:]\n",
    "    candidats_neg = np.argsort(coordonnees_colonnes[:, idx_axe])[:n_top]\n",
    "    \n",
    "    print(f\"\\nCANDIDATS POSITIFS (Axe {num_axe}+):\")\n",
    "    print(\"-\" * 100)\n",
    "    for j in reversed(candidats_pos):\n",
    "        ctr = contributions_colonnes[j, idx_axe] * 100\n",
    "        qual = qualite_colonnes[j, idx_axe]\n",
    "        coord = coordonnees_colonnes[j, idx_axe]\n",
    "        print(f\"{candidates[j]:20s}: Coord={coord:8.4f}  | Contribution={ctr:6.2f}% | Qualité={qual:.3f}\")\n",
    "    \n",
    "    print(f\"\\nCANDIDATS NÉGATIFS (Axe {num_axe}-):\")\n",
    "    print(\"-\" * 100)\n",
    "    for j in reversed(candidats_neg):\n",
    "        ctr = contributions_colonnes[j, idx_axe] * 100\n",
    "        qual = qualite_colonnes[j, idx_axe]\n",
    "        coord = coordonnees_colonnes[j, idx_axe]\n",
    "        print(f\"{candidates[j]:20s}: Coord={coord:8.4f}  | Contribution={ctr:6.2f}% | Qualité={qual:.3f}\")\n",
    "\n",
    "# Analyser les 4 premiers axes\n",
    "for axe in range(1, 5):\n",
    "    analyser_axe(axe, n_top=5)"
