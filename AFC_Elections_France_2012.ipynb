    "print(\"TAUX DE LIAISON - Associations régions-candidats\")\n",
    "print(\"=\"*100)\n",
    "print(f\"\\nFormule: t_ij = (f_ij - f_i. * f_.j) / (sqrt(f_i. * f_.j))\")\n",
    "print(f\"Interprétation:\")\n",
    "print(f\"  - t_ij > 0 : association positive (vote + que moyenne)\")\n",
    "print(f\"  - t_ij < 0 : association négative (vote - que moyenne)\")\n",
    "print(f\"\\n\")\n",
    "\n",
    "# Créer une table des taux de liaison\n",
