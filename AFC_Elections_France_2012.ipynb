    "## 13. Analyse Géométrique et Reconstitution"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Vérification de la propriété de reconstruction\n",
    "\n",
    "On peut reconstituer les taux de liaison à partir des coordonnées :\n",
    "\n",
    "$$t_{ij} = \\sum_{\\text{axes}} \\frac{\\psi_{ik} \\phi_{jk}}{\\lambda_k}$$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Reconstitution des taux de liaison\n",
    "# t_ij = somme sur k de (Psi_ik * Phi_jk) / lambda_k\n",
    "\n",
    "t_reconstitue = np.zeros((len(df.index), len(df.columns)))\n",
    "for k in range(len(Lambda)):\n",
    "    t_reconstitue += (coordonnees_lignes[:, k:k+1] @ coordonnees_colonnes[:, k:k+1].T) / (Lambda[k])\n",
    "\n",
    "# Comparaison avec les taux originaux\n",
    "t_original = residus_standardises\n",
    "\n",
    "print(\"RECONSTITUTION DES DONNÉES\")\n",
    "print(\"=\"*100)\n",
    "print(\"\\nComparaison entre taux de liaison reconstitués et taux originaux\")\n",
    "print(\"-\" * 100)\n",
    "\n",
    "# Calcul de l'erreur de reconstruction\n",
    "erreur = np.abs(t_original - t_reconstitue)\n",
    "erreur_max = erreur.max()\n",
    "erreur_rmse = np.sqrt((erreur ** 2).mean())\n",
    "\n",
    "print(f\"Erreur maximale: {erreur_max:.8f}\")\n",
    "print(f\"Erreur RMSE: {erreur_rmse:.8f}\")\n",
    "print(f\"\\nLa reconstruction est très précise (4 axes capturent {pct_inertie_cumul[3]:.2f}%)\\n\")\n",
    "\n",
    "# Exemple: Alsace et Hollande\n",
    "i_alsace = 0  # Alsace\n",
    "j_hollande = 0  # Hollande\n",
    "\n",
    "print(f\"Exemple: Taux de liaison pour Alsace-Hollande\")\n",
    "print(\"-\" * 100)\n",
    "print(f\"Taux original: {t_original[i_alsace, j_hollande]:.6f}\")\n",
    "print(f\"Taux reconstitué: {t_reconstitue[i_alsace, j_hollande]:.6f}\")\n",
    "print(f\"Erreur: {erreur[i_alsace, j_hollande]:.8f}\")\n",
    "\n",
    "# Détail par axe\n",
    "print(f\"\\nDécomposition par axe:\")\n",
    "for k in range(4):\n",
    "    terme_k = (coordonnees_lignes[i_alsace, k] * coordonnees_colonnes[j_hollande, k]) / Lambda[k]\n",
    "    print(f\"  Axe {k+1}: {terme_k:10.6f}\")\n",
    "print(f\"  {'Somme':10s}: {t_reconstitue[i_alsace, j_hollande]:.6f}\")"
   ]
