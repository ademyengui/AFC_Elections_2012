    "## 13. Matrice de Reconstruction\n",
    "\n",
    "On peut reconstruire les taux de liaison à partir des coordonnées factorielles:\n",
    "$$t_{ij} = \\sum_k \\frac{\\Psi_{ik} \\Phi_{jk}}{\\sqrt{\\lambda_k}}$$"
   ]
  },
  {
   "cell_type": {"text/plain": ""}
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Reconstruction des taux de liaison\n",
    "t_reconstructed = np.zeros((len(profils_lignes), len(profils_colonnes)))\n",
    "for k in range(n_axes):\n",
    "    t_reconstructed += (psi[:, k:k+1] * phi[:, k:k+1].T) / np.sqrt(eigenvalues[k])\n",
    "\n",
    "t_reconstructed_df = pd.DataFrame(\n",
    "    t_reconstructed,\n",
    "    index=profils_lignes.index,\n",
    "    columns=profils_colonnes.index\n",
    ")\n",
    "\n",
    "# Comparer avec les taux de liaison observés\n",
    "erreur_reconstruction = (t_ij - t_reconstructed_df).abs().sum().sum()\n",
    "print(\"=\"*80)\n",
    "print(\"QUALITÉ DE LA RECONSTRUCTION\")\n",
    "print(\"=\"*80)\n",
    "print(f\"Erreur absolue totale: {erreur_reconstruction:.6f}\")\n",
    "print(f\"\\nNote: Une faible erreur indique une bonne reconstruction par les {n_axes} axes.\")\n",
    "print(f\"\\nTaux de liaison observés vs reconstruits (premiers éléments):\")\n",
    "print(\"\\nObservés:\")\n",
    "print(t_ij.iloc[:5, :5].round(4))\n",
    "print(\"\\nReconstruits:\")\n",
    "print(t_reconstructed_df.iloc[:5, :5].round(4))"
   ]
  },
