  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Board Encoder (Lc0 112-plane)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class BoardEncoder:\n",
    "    def __init__(self, history_size=8):\n",
    "        self.history_size = history_size\n",
    "    \n",
    "    def encode(self, board, move_history=None):\n",
    "        tensor = torch.zeros(112, 8, 8, dtype=torch.float32)\n",
    "        \n",
    "        boards = move_history[-self.history_size:] if move_history else [board]\n",
    "        while len(boards) < self.history_size:\n",
    "            boards.insert(0, chess.Board())\n",
    "        \n",
    "        for t, hist_board in enumerate(boards[-self.history_size:]):\n",
    "            plane_offset = t * 13\n",
    "            \n",
    "            for piece_type in range(1, 7):\n",
    "                plane_idx = plane_offset + (piece_type - 1)\n",
    "                for square in hist_board.pieces(piece_type, chess.WHITE):\n",
    "                    row, col = square // 8, square % 8\n",
    "                    tensor[plane_idx, row, col] = 1.0\n",
    "            \n",
    "            for piece_type in range(1, 7):\n",
    "                plane_idx = plane_offset + 6 + (piece_type - 1)\n",
    "                for square in hist_board.pieces(piece_type, chess.BLACK):\n",
    "                    row, col = square // 8, square % 8\n",
    "                    tensor[plane_idx, row, col] = 1.0\n",
    "            \n",
    "            if hist_board.turn == chess.BLACK:\n",
    "                tensor[plane_offset + 12, :, :] = 1.0\n",
    "        \n",
    "        if board.has_kingside_castling_rights(chess.WHITE):\n",
    "            tensor[104, :, :] = 1.0\n",
    "        if board.has_queenside_castling_rights(chess.WHITE):\n",
    "            tensor[105, :, :] = 1.0\n",
    "        if board.has_kingside_castling_rights(chess.BLACK):\n",
    "            tensor[106, :, :] = 1.0\n",
    "        if board.has_queenside_castling_rights(chess.BLACK):\n",
    "            tensor[107, :, :] = 1.0\n",
    "        \n",
    "        if board.turn == chess.BLACK:\n",
    "            tensor[108, :, :] = 1.0\n",
    "        \n",
    "        tensor[109, :, :] = board.halfmove_clock / 100.0\n",
    "        tensor[111, :, :] = 1.0\n",
    "        \n",
    "        return tensor\n",
    "\nencoder = BoardEncoder()\ntest = encoder.encode(chess.Board())\nprint(f\"Encoder shape: {test.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Network (Lc0)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ResidualBlock(nn.Module):\n",
    "    def __init__(self, filters):\n",
    "        super().__init__()\n",
    "        self.conv1 = nn.Conv2d(filters, filters, kernel_size=3, padding=1)\n",
    "        self.bn1 = nn.BatchNorm2d(filters)\n",
    "        self.conv2 = nn.Conv2d(filters, filters, kernel_size=3, padding=1)\n",
    "        self.bn2 = nn.BatchNorm2d(filters)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        residual = x\n",
    "        out = torch.relu(self.bn1(self.conv1(x)))\n",
    "        out = self.bn2(self.conv2(out))\n",
    "        return torch.relu(out + residual)\n",
    "\n",
    "\n",
    "class ChessNetLc0(nn.Module):\n",
    "    def __init__(self, filters=128, blocks=6):\n",
    "        super().__init__()\n",
    "        self.input_conv = nn.Conv2d(112, filters, kernel_size=3, padding=1)\n",
    "        self.input_bn = nn.BatchNorm2d(filters)\n",
    "        self.res_blocks = nn.Sequential(*[ResidualBlock(filters) for _ in range(blocks)])\n",
    "        \n",
    "        self.policy_conv = nn.Conv2d(filters, 64, kernel_size=3, padding=1)\n",
    "        self.policy_bn = nn.BatchNorm2d(64)\n",
    "        self.policy_fc = nn.Linear(64 * 64, 4672)\n",
    "        \n",
    "        self.value_conv = nn.Conv2d(filters, 32, kernel_size=1)\n",
    "        self.value_bn = nn.BatchNorm2d(32)\n",
    "        self.value_fc1 = nn.Linear(32 * 64, 128)\n",
    "        self.value_fc2 = nn.Linear(128, 1)\n",
    "        \n",
    "        self.wdl_conv = nn.Conv2d(filters, 32, kernel_size=1)\n",
    "        self.wdl_bn = nn.BatchNorm2d(32)\n",
    "        self.wdl_fc1 = nn.Linear(32 * 64, 128)\n",
    "        self.wdl_fc2 = nn.Linear(128, 3)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        x = torch.relu(self.input_bn(self.input_conv(x)))\n",
    "        x = self.res_blocks(x)\n",
    "        \n",
    "        p = torch.relu(self.policy_bn(self.policy_conv(x)))\n",
    "        p = p.view(p.size(0), -1)\n",
    "        policy = torch.softmax(self.policy_fc(p), dim=1)\n",
    "        \n",
    "        v = torch.relu(self.value_bn(self.value_conv(x)))\n",
    "        v = v.view(v.size(0), -1)\n",
    "        v = torch.relu(self.value_fc1(v))\n",
    "        value = torch.tanh(self.value_fc2(v))\n",
    "        \n",
    "        w = torch.relu(self.wdl_bn(self.wdl_conv(x)))\n",
    "        w = w.view(w.size(0), -1)\n",
    "        w = torch.relu(self.wdl_fc1(w))\n",
    "        wdl = torch.softmax(self.wdl_fc2(w), dim=1)\n",
    "        \n",
    "        return policy, value, wdl\n",
    "\nnet = ChessNetLc0(filters=128, blocks=6).to(device)\nprint(f\"Network: {sum(p.numel() for p in net.parameters()):,} params\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Move Selection (Aggressive)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def select_move_aggressive(board, network, encoder):\n",
    "    legal_moves = list(board.legal_moves)\n",
    "    if not legal_moves:\n",
    "        return None\n",
    "    \n",
    "    move_scores = []\n",
    "    \n",
    "    for move in legal_moves:\n",
    "        board.push(move)\n",
    "        tensor = encoder.encode(board).unsqueeze(0).to(device)\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            _, value, _ = network(tensor)\n",
    "            score = value.item()\n",
    "        \n",
    "        # AGGRESSIVE BONUSES\n",
    "        if board.is_checkmate():\n",
    "            score += 100.0\n",
    "        elif board.is_check():\n",
    "            score += 10.0\n",
    "        \n",
    "        # Capture bonus\n",
    "        captured = board.piece_at(move.to_square)\n",
    "        if captured:\n",
    "            piece_values = {1: 1, 2: 3, 3: 3, 4: 5, 5: 9}\n",
    "            capture_val = piece_values.get(captured.piece_type, 1)\n",
    "            score += capture_val * 0.5\n",
    "        \n",
    "        board.pop()\n",
    "        move_scores.append(score)\n",
    "    \n",
    "    best_idx = np.argmax(move_scores)\n",
    "    return legal_moves[best_idx]\n",
    "\nprint(\"Move selector ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Stockfish Bot"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class StockfishBot:\n",
    "    def __init__(self, depth=1):\n",
    "        self.engine = chess.engine.SimpleEngine.popen_uci('/usr/games/stockfish')\n",
    "        self.depth = depth\n",
    "    \n",
    "    def select_move(self, board):\n",
    "        try:\n",
    "            result = self.engine.play(board, chess.engine.Limit(depth=self.depth))\n",
    "            return result.move\n",
    "        except:\n",
    "            return random.choice(list(board.legal_moves))\n",
    "    \n",
    "    def set_depth(self, depth):\n",
    "        self.depth = depth\n",
    "    \n",
    "    def quit(self):\n",
    "        self.engine.quit()\n",
    "\nprint(\"Stockfish ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Play vs Stockfish"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def play_game(network, encoder, stockfish_bot, nn_is_white=True, max_moves=200):\n",
    "    board = chess.Board()\n",
    "    game_moves = []\n",
    "    move_list = []\n",
    "    \n",
    "    for _ in range(max_moves):\n",
    "        if board.is_game_over():\n",
    "            result = board.result()\n",
    "            if result == '1-0':\n",
    "                winner = 0 if nn_is_white else 1\n",
    "            elif result == '0-1':\n",
    "                winner = 1 if nn_is_white else 0\n",
    "            else:\n",
    "                winner = 2\n",
    "            \n",
    "            pgn = _make_pgn(move_list, result)\n",
    "            return winner, game_moves, pgn\n",
    "        \n",
    "        is_nn_turn = (board.turn == chess.WHITE) if nn_is_white else (board.turn == chess.BLACK)\n",
    "        board_tensor = encoder.encode(board)\n",
    "        \n",
    "        if is_nn_turn:\n",
    "            move = select_move_aggressive(board, network, encoder)\n",
    "        else:\n",
    "            move = stockfish_bot.select_move(board)\n",
    "        \n",
    "        if not move:\n",
    "            break\n",
    "        \n",
    "        board.push(move)\n",
    "        move_list.append(move)\n",
    "        \n",
    "        if is_nn_turn:\n",
    "            game_moves.append({'board': board_tensor, 'move': move})\n",
    "    \n",
    "    pgn = _make_pgn(move_list, '*')\n",
    "    return 2, game_moves, pgn\n",
    "\n\ndef _make_pgn(moves, result):\n",
    "    game = chess.pgn.Game()\n",
    "    node = game\n",
    "    for move in moves:\n",
    "        node = node.add_variation(move)\n",
    "    game.headers[\"Event\"] = \"NN vs Stockfish\"\n",
    "    game.headers[\"Result\"] = result\n",
    "    return str(game)\n",
    "\nprint(\"Game engine ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Aggressive Training"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_aggressive(network, optimizer, game_moves, winner, learning_rate=0.001):\n",
    "    if not game_moves:\n",
    "        return 0.0\n",
    "    \n",
    "    network.train()\n",
    "    total_loss = 0.0\n",
    "    batch_size = 16\n",
    "    \n",
    "    for i in range(0, len(game_moves), batch_size):\n",
    "        batch_moves = game_moves[i:i+batch_size]\n",
    "        boards = torch.stack([m['board'] for m in batch_moves]).to(device)\n",
    "        \n",
    "        policy, value, wdl = network(boards)\n",
    "        \n",
    "        # VALUE TARGET\n",
    "        if winner == 0 or winner == 1:  # NN won\n",
    "            value_target = 1.0\n",
    "            loss_weight = 0.5  # WINNING CHEAP\n",
    "        elif winner == 2:  # DRAW\n",
    "            value_target = -0.3  # PENALIZE\n",
    "            loss_weight = 3.0   # EXPENSIVE\n",
    "        else:  # LOSS\n",
    "            value_target = -1.0\n",
    "            loss_weight = 2.0\n",
    "        \n",
    "        value_targets = torch.tensor([[value_target]] * len(batch_moves), dtype=torch.float32).to(device)\n",
    "        \n",
    "        # WDL TARGET\n",
    "        if winner == 0 or winner == 1:\n",
    "            wdl_target = torch.tensor([[1, 0, 0]], dtype=torch.float32).to(device).expand(len(batch_moves), -1)\n",
    "        else:\n",
    "            wdl_target = torch.tensor([[0, 1, 0]], dtype=torch.float32).to(device).expand(len(batch_moves), -1)\n",
    "        \n",
    "        # LOSSES WITH WEIGHTING\n",
    "        value_loss = torch.mean((value - value_targets) ** 2) * loss_weight\n",
    "        wdl_loss = -torch.sum(wdl_target * torch.log(wdl + 1e-8)) / len(batch_moves)\n",
    "        \n",
    "        loss = value_loss + wdl_loss\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(network.parameters(), max_norm=1.0)\n",
    "        optimizer.step()\n",
    "        \n",
    "        total_loss += loss.item()\n",
    "    \n",
    "    network.eval()\n",
    "    return total_loss / max(1, len(game_moves) // batch_size)\n",
    "\nprint(\"Training ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Save/Load"
   ]
  },
  {
   "cell_type": {"label": "checkpoint"} },
   "outputs": [],
   "source": [
    "def save_ckpt(network, optimizer, episode, depth, drive_path):\n",
    "    ckpt = {\n",
    "        'episode': episode,\n",
    "        'depth': depth,\n",
    "        'model': network.state_dict(),\n",
    "        'optimizer': optimizer.state_dict(),\n",
    "    }\n",
    "    path = drive_path / f'ckpt_ep{episode}_d{depth}.pt'\n",
    "    torch.save(ckpt, path)\n",
    "    return path\n",
    "\n",
    "\ndef load_ckpt(path):\n",
    "    ckpt = torch.load(path, map_location=device)\n",
    "    net = ChessNetLc0(filters=128, blocks=6).to(device)\n",
    "    opt = optim.Adam(net.parameters(), lr=0.001)\n",
    "    net.load_state_dict(ckpt['model'])\n",
    "    opt.load_state_dict(ckpt['optimizer'])\n",
    "    return net, opt, ckpt['episode'], ckpt['depth']\n",
    "\nprint(\"Save/load ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Stats"
   ]
  },
  {
   "cell_type": {"label": "stats"} },
   "outputs": [],
   "source": [
    "class Stats:\n",
    "    def __init__(self, drive_path):\n",
    "        self.drive_path = drive_path\n",
    "        self.file = drive_path / 'stats.json'\n",
    "        self.stats = {\n",
    "            'depth': 1,\n",
    "            'games': {},\n",
    "            'all_games': 0,\n",
    "            'total_w': 0,\n",
    "            'total_d': 0,\n",
    "            'total_l': 0,\n",
    "            'history': [],\n",
    "            'losses': []\n",
    "        }\n",
    "        if self.file.exists():\n",
    "            with open(self.file) as f:\n",
    "                self.stats = json.load(f)\n",
    "    \n",
    "    def record(self, winner, depth, loss):\n",
    "        self.stats['all_games'] += 1\n",
    "        self.stats['losses'].append(loss)\n",
    "        self.stats['history'].append('W' if winner in [0, 1] else ('D' if winner == 2 else 'L'))\n",
    "        \n",
    "        d_str = str(depth)\n",
    "        if d_str not in self.stats['games']:\n",
    "            self.stats['games'][d_str] = {'w': 0, 'd': 0, 'l': 0}\n",
    "        \n",
    "        if winner in [0, 1]:\n",
    "            self.stats['games'][d_str]['w'] += 1\n",
    "            self.stats['total_w'] += 1\n",
    "        elif winner == 2:\n",
    "            self.stats['games'][d_str]['d'] += 1\n",
    "            self.stats['total_d'] += 1\n",
    "        else:\n",
    "            self.stats['games'][d_str]['l'] += 1\n",
    "            self.stats['total_l'] += 1\n",
    "        \n",
    "        self.stats['history'] = self.stats['history'][-100:]\n",
    "    \n",
    "    def get_wr(self, depth):\n",
    "        d_str = str(depth)\n",
    "        if d_str not in self.stats['games']:\n",
    "            return 0.0\n",
    "        g = self.stats['games'][d_str]\n",
    "        total = g['w'] + g['d'] + g['l']\n",
    "        return g['w'] / total if total > 0 else 0.0\n",
    "    \n",
    "    def save(self):\n",
    "        with open(self.file, 'w') as f:\n",
    "            json.dump(self.stats, f, indent=2)\n",
    "    \n",
    "    def print(self, depth):\n",
    "        d_str = str(depth)\n",
    "        if d_str not in self.stats['games']:\n",
    "            return\n",
    "        g = self.stats['games'][d_str]\n",
    "        total = g['w'] + g['d'] + g['l']\n",
    "        if total == 0:\n",
    "            return\n",
    "        avg_loss = np.mean(self.stats['losses'][-20:]) if self.stats['losses'] else 0\n",
    "        print(f\"  Depth {depth} | W:{g['w']:2d} ({100*g['w']/total:5.1f}%) D:{g['d']:2d} L:{g['l']:2d} | Loss:{avg_loss:.4f}\")\n",
    "\nstats = Stats(drive_path)\nprint(\"Stats ready\")"
   ]
  },
  {
   "cell_type": {"label": "main_loop"} },
   "outputs": [],
   "source": [
    "WIN_THRESHOLD = 0.60\n",
    "GAMES_PER_LEVEL = 50\n",
    "LR = 0.001\n",
    "START_DEPTH = 1\n",
    "\n",
    "print(\"\\nCURRICULUM: NN vs Stockfish\")\n",
    "print(f\"Threshold: {WIN_THRESHOLD*100:.0f}%\")\n",
    "print(f\"Games/level: {GAMES_PER_LEVEL}\")\n",
    "print(f\"Start depth: {START_DEPTH}\\n\")\n",
    "\n",
    "checkpoints = sorted(drive_path.glob('ckpt_*.pt'))\n",
    "start_ep = 0\n",
    "current_depth = START_DEPTH\n",
    "\n",
    "if checkpoints:\n",
    "    print(f\"Loading: {checkpoints[-1].name}\")\n",
    "    net, optimizer, start_ep, current_depth = load_ckpt(checkpoints[-1])\n",
    "    print(f\"Resumed ep {start_ep}, depth {current_depth}\")\n",
    "    stats.print(current_depth)\nelse:\n",
    "    net = ChessNetLc0(filters=128, blocks=6).to(device)\n",
    "    optimizer = optim.Adam(net.parameters(), lr=LR)\n",
    "    net.eval()\n",
    "    print(\"Fresh start\")\n",
    "\nstockfish = StockfishBot(depth=current_depth)\nprint(f\"Stockfish depth: {current_depth}\\n\")\n",
    "\nscheduler = optim.lr_scheduler.StepLR(optimizer, step_size=100, gamma=0.5)\nlast_pgn = None\nepisode = start_ep\n",
    "\ntry:\n",
    "    while True:\n",
    "        # PLAY\n",
    "        winner, game_moves, pgn = play_game(\n",
    "            net, encoder, stockfish, nn_is_white=(episode % 2 == 0)\n",
    "        )\n",
    "        last_pgn = pgn\n",
    "        \n",
    "        # TRAIN\n",
    "        loss = train_aggressive(net, optimizer, game_moves, winner, LR)\n",
    "        \n",
    "        # RECORD\n",
    "        stats.record(winner, current_depth, loss)\n",
    "        episode += 1\n",
    "        \n",
    "        # PROGRESS\n",
    "        if episode % 10 == 0:\n",
    "            print(f\"Ep {episode:4d} | \", end='')\n",
    "            stats.print(current_depth)\n",
    "        \n",
    "        # CHECK LEVEL UP\n",
    "        games_at_depth = sum([1 for h in stats.stats['history'] if stats.stats['depth'] == current_depth])\n",
    "        \n",
    "        if len([h for i, h in enumerate(stats.stats['history']) if i >= len(stats.stats['history']) - GAMES_PER_LEVEL]) >= GAMES_PER_LEVEL:\n",
    "            wr = stats.get_wr(current_depth)\n",
    "            if wr >= WIN_THRESHOLD:\n",
    "                new_depth = current_depth + 1\n",
    "                stockfish.set_depth(new_depth)\n",
    "                current_depth = new_depth\n",
    "                print(f\"\\n🚀 LEVEL UP! {current_depth-1} → {current_depth} (WR: {wr*100:.1f}%)\\n\")\n",
    "        \n",
    "        # SAVE\n",
    "        if episode % 20 == 0:\n",
    "            save_ckpt(net, optimizer, episode, current_depth, drive_path)\n",
    "            stats.save()\n",
    "            print(f\"Saved\\n\")\n",
    "        \n",
    "        if current_depth >= 20:\n",
    "            print(f\"\\nMax depth {current_depth}\")\n",
    "            break\n",
    "        \n",
    "        scheduler.step()\n",
    "\nexcept KeyboardInterrupt:\n",
    "    print(f\"\\nInterrupted at ep {episode}\")\n",
    "    save_ckpt(net, optimizer, episode, current_depth, drive_path)\n",
    "    stats.save()\n",
    "\nfinally:\n",
    "    stockfish.quit()\n",
    "    print(\"Done\")\n",
    "\nprint(f\"\\nLast game:\\n{last_pgn}\")"
   ]
  },
