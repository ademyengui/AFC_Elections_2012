   "cell_type": "markdown",
   "metadata": {
    "id": "encoder_lc0"
   },
   "source": [
    "## 2. Lc0 Board Encoder (112-plane)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "encoder"
   },
   "outputs": [],
   "source": [
    "class BoardEncoder:\n",
    "    \"\"\"Lc0-style 8×8×112 encoding.\"\"\"\n",
    "    \n",
    "    def __init__(self, history_size=8):\n",
    "        self.history_size = history_size\n",
    "    \n",
    "    def encode(self, board, move_history=None):\n",
    "        \"\"\"Encode board + history into 112-plane tensor.\"\"\"\n",
    "        tensor = torch.zeros(112, 8, 8, dtype=torch.float32)\n",
    "        \n",
    "        # Use history if provided\n",
    "        boards = move_history[-self.history_size:] if move_history else [board]\n",
    "        while len(boards) < self.history_size:\n",
    "            boards.insert(0, chess.Board())\n",
    "        \n",
    "        # Planes 0-103: 8 timesteps × 13 planes each\n",
    "        for t, hist_board in enumerate(boards[-self.history_size:]):\n",
    "            plane_offset = t * 13\n",
    "            \n",
    "            # White pieces (planes 0-5)\n",
    "            for piece_type in range(1, 7):\n",
    "                plane_idx = plane_offset + (piece_type - 1)\n",
    "                for square in hist_board.pieces(piece_type, chess.WHITE):\n",
    "                    row, col = square // 8, square % 8\n",
    "                    tensor[plane_idx, row, col] = 1.0\n",
    "            \n",
    "            # Black pieces (planes 6-11)\n",
    "            for piece_type in range(1, 7):\n",
    "                plane_idx = plane_offset + 6 + (piece_type - 1)\n",
    "                for square in hist_board.pieces(piece_type, chess.BLACK):\n",
    "                    row, col = square // 8, square % 8\n",
    "                    tensor[plane_idx, row, col] = 1.0\n",
    "            \n",
    "            # Side to move (plane 12)\n",
    "            if hist_board.turn == chess.BLACK:\n",
    "                tensor[plane_offset + 12, :, :] = 1.0\n",
    "        \n",
    "        # Planes 104-107: Castling rights\n",
    "        if board.has_kingside_castling_rights(chess.WHITE):\n",
    "            tensor[104, :, :] = 1.0\n",
    "        if board.has_queenside_castling_rights(chess.WHITE):\n",
    "            tensor[105, :, :] = 1.0\n",
    "        if board.has_kingside_castling_rights(chess.BLACK):\n",
    "            tensor[106, :, :] = 1.0\n",
    "        if board.has_queenside_castling_rights(chess.BLACK):\n",
    "            tensor[107, :, :] = 1.0\n",
    "        \n",
    "        # Plane 108: Side to move\n",
    "        if board.turn == chess.BLACK:\n",
    "            tensor[108, :, :] = 1.0\n",
    "        \n",
    "        # Plane 109: Halfmove clock\n",
    "        tensor[109, :, :] = board.halfmove_clock / 100.0\n",
    "        \n",
    "        # Plane 111: Ones\n",
    "        tensor[111, :, :] = 1.0\n",
    "        \n",
    "        return tensor\n",
    "\nencoder = BoardEncoder()\ntest = encoder.encode(chess.Board())\nprint(f\"✓ Board encoder: {test.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "network_lc0"
   },
   "source": [
    "## 3. Lc0 Network Architecture"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "network"
   },
   "outputs": [],
   "source": [
    "class ResidualBlock(nn.Module):\n",
    "    \"\"\"Residual block.\"\"\"\n",
    "    def __init__(self, filters):\n",
    "        super().__init__()\n",
    "        self.conv1 = nn.Conv2d(filters, filters, kernel_size=3, padding=1)\n",
    "        self.bn1 = nn.BatchNorm2d(filters)\n",
    "        self.conv2 = nn.Conv2d(filters, filters, kernel_size=3, padding=1)\n",
    "        self.bn2 = nn.BatchNorm2d(filters)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        residual = x\n",
    "        out = torch.relu(self.bn1(self.conv1(x)))\n",
    "        out = self.bn2(self.conv2(out))\n",
    "        return torch.relu(out + residual)\n",
    "\n\nclass ChessNetLc0(nn.Module):\n",
    "    \"\"\"Lc0-style network with Policy, Value, WDL heads.\"\"\"\n",
    "    \n",
    "    def __init__(self, filters=128, blocks=6):\n",
    "        super().__init__()\n",
    "        self.filters = filters\n",
    "        \n",
    "        # Input\n",
    "        self.input_conv = nn.Conv2d(112, filters, kernel_size=3, padding=1)\n",
    "        self.input_bn = nn.BatchNorm2d(filters)\n",
    "        \n",
    "        # Residual blocks\n",
    "        self.res_blocks = nn.Sequential(*[ResidualBlock(filters) for _ in range(blocks)])\n",
    "        \n",
    "        # Policy head\n",
    "        self.policy_conv = nn.Conv2d(filters, 64, kernel_size=3, padding=1)\n",
    "        self.policy_bn = nn.BatchNorm2d(64)\n",
    "        self.policy_fc = nn.Linear(64 * 64, 4672)\n",
    "        \n",
    "        # Value head\n",
    "        self.value_conv = nn.Conv2d(filters, 32, kernel_size=1)\n",
    "        self.value_bn = nn.BatchNorm2d(32)\n",
    "        self.value_fc1 = nn.Linear(32 * 64, 128)\n",
    "        self.value_fc2 = nn.Linear(128, 1)\n",
    "        \n",
    "        # WDL head\n",
    "        self.wdl_conv = nn.Conv2d(filters, 32, kernel_size=1)\n",
    "        self.wdl_bn = nn.BatchNorm2d(32)\n",
    "        self.wdl_fc1 = nn.Linear(32 * 64, 128)\n",
    "        self.wdl_fc2 = nn.Linear(128, 3)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        x = torch.relu(self.input_bn(self.input_conv(x)))\n",
    "        x = self.res_blocks(x)\n",
    "        \n",
    "        # Policy\n",
    "        p = torch.relu(self.policy_bn(self.policy_conv(x)))\n",
    "        p = p.view(p.size(0), -1)\n",
    "        policy = torch.softmax(self.policy_fc(p), dim=1)\n",
    "        \n",
    "        # Value\n",
    "        v = torch.relu(self.value_bn(self.value_conv(x)))\n",
    "        v = v.view(v.size(0), -1)\n",
    "        v = torch.relu(self.value_fc1(v))\n",
    "        value = torch.tanh(self.value_fc2(v))\n",
    "        \n",
    "        # WDL\n",
    "        w = torch.relu(self.wdl_bn(self.wdl_conv(x)))\n",
    "        w = w.view(w.size(0), -1)\n",
    "        w = torch.relu(self.wdl_fc1(w))\n",
    "        wdl = torch.softmax(self.wdl_fc2(w), dim=1)\n",
    "        \n",
    "        return policy, value, wdl\n",
    "\nnet = ChessNetLc0(filters=128, blocks=6).to(device)\nprint(f\"✓ Network: {sum(p.numel() for p in net.parameters()):,} params\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "mcts_lc0"
   },
   "source": [
    "## 4. Simple MCTS"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "mcts"
   },
   "outputs": [],
   "source": [
    "def select_move_mcts(board, network, encoder, num_sims=50):\n",
    "    \"\"\"Select move using MCTS with network guidance.\"\"\"\n",
    "    legal_moves = list(board.legal_moves)\n",
    "    if not legal_moves:\n",
    "        return None\n",
    "    \n",
    "    # Quick eval: just evaluate all moves once\n",
    "    move_scores = []\n",
    "    \n",
    "    for move in legal_moves:\n",
    "        board.push(move)\n",
    "        tensor = encoder.encode(board).unsqueeze(0).to(device)\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            _, value, _ = network(tensor)\n",
    "            score = value.item()\n",
    "        \n",
    "        board.pop()\n",
    "        move_scores.append(score)\n",
    "    \n",
    "    # Select best\n",
    "    best_idx = np.argmax(move_scores)\n",
    "    best_move = legal_moves[best_idx]\n",
    "    \n",
    "    return best_move\n",
    "\nprint(\"✓ MCTS loaded\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "stockfish_engine"
   },
   "source": [
    "## 5. Stockfish Engine Wrapper"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "stockfish_class"
   },
   "outputs": [],
   "source": [
    "class StockfishBot:\n",
    "    \"\"\"Wrapper for Stockfish engine.\"\"\"\n",
    "    \n",
    "    def __init__(self, depth=1):\n",
    "        self.engine = chess.engine.SimpleEngine.popen_uci('/usr/games/stockfish')\n",
    "        self.depth = depth\n",
    "    \n",
    "    def select_move(self, board):\n",
    "        \"\"\"Get best move from Stockfish.\"\"\"\n",
    "        try:\n",
    "            result = self.engine.play(board, chess.engine.Limit(depth=self.depth))\n",
    "            return result.move\n",
    "        except:\n",
    "            # Fallback: random move\n",
    "            return random.choice(list(board.legal_moves))\n",
    "    \n",
    "    def set_depth(self, depth):\n",
    "        \"\"\"Change difficulty level.\"\"\"\n",
    "        self.depth = depth\n",
    "    \n",
    "    def quit(self):\n",
    "        \"\"\"Shutdown engine.\"\"\"\n",
    "        self.engine.quit()\n",
    "\nprint(\"✓ Stockfish wrapper ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "game_vs_stockfish"
   },
   "source": [
    "## 6. Game vs Stockfish"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "play_vs_sf"
   },
   "outputs": [],
   "source": [
    "def play_vs_stockfish(network, encoder, stockfish_bot, nn_is_white=True, max_moves=200):\n",
    "    \"\"\"\n",
    "    Play NN vs Stockfish.\n",
    "    Returns: winner (0=NN white, 1=NN black, 2=draw), game_moves, pgn\n",
    "    \"\"\"\n",
    "    board = chess.Board()\n",
    "    game_moves = []\n",
    "    move_list = []\n",
    "    \n",
    "    for move_num in range(max_moves):\n",
    "        if board.is_game_over():\n",
    "            result = board.result()\n",
    "            \n",
    "            # Determine winner from NN perspective\n",
    "            if result == '1-0':\n",
    "                winner = 0 if nn_is_white else 1\n",
    "            elif result == '0-1':\n",
    "                winner = 1 if nn_is_white else 0\n",
    "            else:\n",
    "                winner = 2\n",
    "            \n",
    "            pgn = _make_pgn(move_list, result)\n",
    "            return winner, game_moves, pgn\n",
    "        \n",
    "        # Decide whose turn\n",
    "        is_nn_turn = (board.turn == chess.WHITE) if nn_is_white else (board.turn == chess.BLACK)\n",
    "        \n",
    "        # Record state\n",
    "        board_tensor = encoder.encode(board)\n",
    "        \n",
    "        if is_nn_turn:\n",
    "            # NN's move\n",
    "            move = select_move_mcts(board, network, encoder, num_sims=50)\n",
    "            if not move:\n",
    "                break\n",
    "        else:\n",
    "            # Stockfish's move\n",
    "            move = stockfish_bot.select_move(board)\n",
    "            if not move:\n",
    "                break\n",
    "        \n",
    "        board.push(move)\n",
    "        move_list.append(move)\n",
    "        \n",
    "        # Record move if NN's\n",
    "        if is_nn_turn:\n",
    "            game_moves.append({\n",
    "                'board': board_tensor,\n",
    "                'move': move\n",
    "            })\n",
    "    \n",
    "    pgn = _make_pgn(move_list, '*')\n",
    "    return 2, game_moves, pgn\n",
    "\n\ndef _make_pgn(moves, result):\n",
    "    \"\"\"Create PGN from moves.\"\"\"\n",
    "    game = chess.pgn.Game()\n",
    "    node = game\n",
    "    for move in moves:\n",
    "        node = node.add_variation(move)\n",
    "    game.headers[\"Event\"] = \"NN vs Stockfish\"\n",
    "    game.headers[\"White\"] = \"ChessNet\"\n",
    "    game.headers[\"Black\"] = \"Stockfish\"\n",
    "    game.headers[\"Result\"] = result\n",
    "    game.headers[\"Date\"] = datetime.now().strftime(\"%Y.%m.%d\")\n",
    "    return str(game)\n",
    "\nprint(\"✓ Game engine ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "training_vs_sf"
   },
   "source": [
    "## 7. Training Function"
   ]
  },
  {
   "cell_type": {"label": "train_func"} },
   "outputs": [],
   "source": [
    "def train_on_game(network, optimizer, game_moves, winner, learning_rate=0.001):\n",
    "    \"\"\"\n",
    "    Train NN on game against Stockfish.\n",
    "    Only train on positions where NN moved.\n",
    "    \"\"\"\n",
    "    if not game_moves:\n",
    "        return 0.0\n",
    "    \n",
    "    network.train()\n",
    "    total_loss = 0.0\n",
    "    batch_size = 16\n",
    "    \n",
    "    for i in range(0, len(game_moves), batch_size):\n",
    "        batch_moves = game_moves[i:i+batch_size]\n",
    "        \n",
    "        # Stack boards\n",
    "        boards = torch.stack([m['board'] for m in batch_moves]).to(device)\n",
    "        \n",
    "        # Forward pass\n",
    "        policy, value, wdl = network(boards)\n",
    "        \n",
    "        # ========== VALUE TARGET ==========\n",
    "        # If NN won: value → +1\n",
    "        # If NN lost: value → -1\n",
    "        # If draw: value → 0\n",
    "        if winner == 0:  # NN (white) won\n",
    "            value_target = 1.0\n",
    "        elif winner == 1:  # NN (black) won\n",
    "            value_target = 1.0\n",
    "        else:  # Draw\n",
    "            value_target = 0.0\n",
    "        \n",
    "        value_targets = torch.tensor([[value_target]] * len(batch_moves), dtype=torch.float32).to(device)\n",
    "        \n",
    "        # ========== WDL TARGET ==========\n",
    "        if winner == 0 or winner == 1:  # NN won\n",
    "            wdl_target = torch.tensor([[1, 0, 0]], dtype=torch.float32).to(device).expand(len(batch_moves), -1)\n",
    "        else:  # Draw\n",
    "            wdl_target = torch.tensor([[0, 1, 0]], dtype=torch.float32).to(device).expand(len(batch_moves), -1)\n",
    "        \n",
    "        # ========== LOSSES ==========\n",
    "        value_loss = torch.mean((value - value_targets) ** 2)\n",
    "        wdl_loss = -torch.sum(wdl_target * torch.log(wdl + 1e-8)) / len(batch_moves)\n",
    "        \n",
    "        loss = value_loss + wdl_loss\n",
    "        \n",
    "        # Backprop\n",
    "        optimizer.zero_grad()\n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(network.parameters(), max_norm=1.0)\n",
    "        optimizer.step()\n",
    "        \n",
    "        total_loss += loss.item()\n",
    "    \n",
    "    network.eval()\n",
    "    return total_loss / max(1, len(game_moves) // batch_size)\n",
    "\nprint(\"✓ Training function ready\")"
   ]
  },
