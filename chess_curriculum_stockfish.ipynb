   "source": [
    "# Configuration\nWIN_RATE_THRESHOLD = 0.60  # When to increase difficulty\nGAMES_PER_LEVEL = 50      # Games before checking win rate\nLEARNING_RATE = 0.001\nSTART_DEPTH = 1            # Start with weakest Stockfish\n\nprint(\"\\n\" + \"=\"*80)\nprint(\"🎯 CURRICULUM LEARNING: NN vs Stockfish\")\nprint(\"=\"*80)\nprint(f\"WIN_RATE_THRESHOLD: {WIN_RATE_THRESHOLD*100:.0f}%\")\nprint(f\"GAMES_PER_LEVEL: {GAMES_PER_LEVEL}\")\nprint(f\"START_DEPTH: {START_DEPTH}\\n\")\n\n# Auto-load checkpoint\ncheckpoints = sorted(drive_path.glob('ckpt_*.pt'))\nstart_episode = 0\ncurrent_depth = START_DEPTH\n\nif checkpoints:\n",
    "    print(f\"📦 Loading: {checkpoints[-1].name}\")\n",
    "    net, optimizer, start_episode, current_depth = load_ckpt(checkpoints[-1])\n",
    "    print(f\"✓ Resumed from episode {start_episode}, depth {current_depth}\")\n",
    "    stats.print(current_depth)\nelse:\n",
    "    net = ChessNetLc0(filters=128, blocks=6).to(device)\n",
    "    optimizer = optim.Adam(net.parameters(), lr=LEARNING_RATE)\n",
    "    net.eval()\n",
    "    print(\"✓ Fresh start\")\n\n# Initialize Stockfish\nstockfish = StockfishBot(depth=current_depth)\nprint(f\"✓ Stockfish initialized at depth {current_depth}\\n\")\n\nscheduler = optim.lr_scheduler.StepLR(optimizer, step_size=100, gamma=0.5)\nlast_pgn = None\nepisode = start_episode\n\ntry:\n",
    "    while True:\n",
    "        # ========== PLAY GAME ==========\n",
    "        winner, game_moves, pgn = play_vs_stockfish(\n",
    "            net, encoder, stockfish, nn_is_white=(episode % 2 == 0), max_moves=200\n",
    "        )\n",
    "        last_pgn = pgn\n",
    "        \n",
    "        # ========== TRAIN ==========\n",
    "        loss = train_on_game(net, optimizer, game_moves, winner, LEARNING_RATE)\n",
    "        \n",
    "        # ========== RECORD ==========\n",
    "        stats.record(winner, current_depth, loss)\n",
    "        episode += 1\n",
    "        \n",
    "        # ========== PROGRESS ==========\n",
    "        if episode % 10 == 0:\n",
    "            print(f\"Episode {episode:4d} | \", end='')\n",
    "            stats.print(current_depth)\n",
    "        \n",
    "        # ========== CHECK FOR DIFFICULTY INCREASE ==========\n",
    "        games_at_current_depth = stats.stats['games_at_depth'].get(str(current_depth), {}).get('games', 0)\n",
    "        \n",
    "        if games_at_current_depth >= GAMES_PER_LEVEL:\n",
    "            win_rate = stats.get_win_rate_at_depth(current_depth)\n",
    "            \n",
    "            if win_rate >= WIN_RATE_THRESHOLD:\n",
    "                # INCREASE DIFFICULTY!\n",
    "                new_depth = current_depth + 1\n",
    "                stockfish.set_depth(new_depth)\n",
    "                current_depth = new_depth\n",
    "                \n",
    "                print(f\"\\n🚀 LEVEL UP! Depth: {current_depth - 1} → {current_depth}\")\n",
    "                print(f\"   Win rate at depth {current_depth - 1}: {win_rate*100:.1f}%\\n\")\n",
    "        \n",
    "        # ========== SAVE CHECKPOINT ==========\n",
    "        if episode % 20 == 0:\n",
    "            save_ckpt(net, optimizer, episode, current_depth, drive_path)\n",
    "            stats.save()\n",
    "            print(f\"💾 Checkpoint saved\\n\")\n",
    "        \n",
    "        # ========== SAFETY: Stop at depth 20 ==========\n",
    "        if current_depth >= 20:\n",
    "            print(f\"\\n\" + \"=\"*80)\n",
    "            print(f\"✅ REACHED MAXIMUM DEPTH: {current_depth}\")\n",
    "            print(f\"=\"*80)\n",
    "            break\n",
    "        \n",
    "        scheduler.step()\n\nexcept KeyboardInterrupt:\n",
    "    print(f\"\\n⚠️  Training interrupted at episode {episode}\")\n",
    "    save_ckpt(net, optimizer, episode, current_depth, drive_path)\n",
    "    stats.save()\n",
    "    print(\"✓ Checkpoint saved\")\n\nfinally:\n",
    "    stockfish.quit()\n",
    "    print(\"\\n✓ Stockfish shutdown\")\n",
    "\nprint(\"\\n\" + \"=\"*80)\nprint(\"📋 FINAL GAME (PGN):\")\nprint(\"=\"*80)\nif last_pgn:\n",
    "    print(last_pgn)\nelse:\n",
    "    print(\"No game\")"
