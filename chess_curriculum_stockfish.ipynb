   "source": [
    "## 9. Stats Tracker"
   ]
  },
  {
   "cell_type": {"label": "stats_class"} },
   "outputs": [],
   "source": [
    "class CurriculumStats:\n",
    "    def __init__(self, drive_path):\n",
    "        self.drive_path = drive_path\n",
    "        self.stats_file = drive_path / 'curriculum_stats.json'\n",
    "        self.stats = {\n",
    "            'current_depth': 1,\n",
    "            'games_at_depth': {},  # depth → {wins, losses, draws, games}\n",
    "            'all_games': 0,\n",
    "            'total_wins': 0,\n",
    "            'total_losses': 0,\n",
    "            'total_draws': 0,\n",
    "            'history': [],  # [depth, result] pairs\n",
    "            'losses': []\n",
    "        }\n",
    "        if self.stats_file.exists():\n",
    "            with open(self.stats_file) as f:\n",
    "                self.stats = json.load(f)\n",
    "    \n",
    "    def record(self, winner, depth, loss):\n",
    "        \"\"\"Record game result.\"\"\"\n",
    "        self.stats['all_games'] += 1\n",
    "        self.stats['losses'].append(loss)\n",
    "        self.stats['history'].append([depth, 'W' if winner == 0 or winner == 1 else 'D'])\n",
    "        \n",
    "        if depth not in self.stats['games_at_depth']:\n",
    "            self.stats['games_at_depth'][str(depth)] = {'wins': 0, 'losses': 0, 'draws': 0}\n",
    "        \n",
    "        if winner == 0 or winner == 1:  # NN won\n",
    "            self.stats['games_at_depth'][str(depth)]['wins'] += 1\n",
    "            self.stats['total_wins'] += 1\n",
    "        elif winner == 2:  # Draw\n",
    "            self.stats['games_at_depth'][str(depth)]['draws'] += 1\n",
    "            self.stats['total_draws'] += 1\n",
    "        else:  # NN lost\n",
    "            self.stats['games_at_depth'][str(depth)]['losses'] += 1\n",
    "            self.stats['total_losses'] += 1\n",
    "        \n",
    "        self.stats['games_at_depth'][str(depth)]['games'] = sum([\n",
    "            self.stats['games_at_depth'][str(depth)]['wins'],\n",
    "            self.stats['games_at_depth'][str(depth)]['losses'],\n",
    "            self.stats['games_at_depth'][str(depth)]['draws']\n",
    "        ])\n",
    "    \n",
    "    def get_win_rate_at_depth(self, depth):\n",
    "        \"\"\"Get recent win rate at current depth.\"\"\"\n",
    "        if depth not in self.stats['games_at_depth']:\n",
    "            return 0.0\n",
    "        \n",
    "        d = self.stats['games_at_depth'][str(depth)]\n",
    "        total = d['games']\n",
    "        if total == 0:\n",
    "            return 0.0\n",
    "        \n",
    "        return d['wins'] / total\n",
    "    \n",
    "    def save(self):\n",
    "        with open(self.stats_file, 'w') as f:\n",
    "            json.dump(self.stats, f, indent=2)\n",
    "    \n",
    "    def print(self, depth):\n",
    "        if depth not in self.stats['games_at_depth']:\n",
    "            return\n",
    "        \n",
    "        d = self.stats['games_at_depth'][str(depth)]\n",
    "        w, l, dr = d['wins'], d['losses'], d['draws']\n",
    "        total = w + l + dr\n",
    "        \n",
    "        if total == 0:\n",
    "            return\n",
    "        \n",
    "        avg_loss = np.mean(self.stats['losses'][-20:]) if self.stats['losses'] else 0\n",
    "        \n",
    "        print(f\"  Depth {depth}: W:{w:2d} ({100*w/total:5.1f}%) | L:{l:2d} ({100*l/total:5.1f}%) | D:{dr:2d} ({100*dr/total:5.1f}%) | Loss:{avg_loss:.4f}\")\n",
    "\nstats = CurriculumStats(drive_path)\nprint(\"✓ Stats ready\")"
   ]
